{
    "manifest_version": 3,
    "name": "XPlus - Disable Feed & More on 𝕏",
    "version": "1.5.0",
    "description": "Feed control and focus tools for X, including redirects, filters, and usage tracking",
    "permissions": ["tabs", "storage", "declarativeNetRequest", "alarms", "notifications", "idle"],
    "host_permissions": ["https://x.com/*", "https://*.x.com/*"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "XPlus",
        "default_popup": "popup.html"
    },
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "ruleset_home_redirect",
                "enabled": false,
                "path": "redirect-rules.json"
            },
            {
                "id": "ruleset_explore_redirect",
                "enabled": false,
                "path": "explore-redirect-rules.json"
            }
        ]
    },
    "content_scripts": [
        {
            "matches": ["https://*.x.com/*"],
            "js": ["content.js"]
        },
        {
            "matches": ["https://x.com/*"],
            "js": ["redirect.js"],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "16": "assets/icon16.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    }
}
